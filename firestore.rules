rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Match rules
    match /users/{userId} {
      // Any authenticated user can read profiles (e.g. clients/professionals lookup)
      allow read: if isSignedIn();
      // Only the user themselves can manage their profile
      allow create, update, delete: if isOwner(userId);

      match /data/{dataId} {
        // Only the owner can access their personalized data subcollection
        allow read, write: if isOwner(userId);
      }
    }
  }
}
